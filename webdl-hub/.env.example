# --- WebDL-Hub configuratie ---
# Kopieer naar .env en pas aan naar eigen omgeving.

# HTTP-poort van de hub (naast screen-recorder-native op 35729).
PORT=35730

# PostgreSQL-connectie (hergebruik bestaande webdl-database).
DATABASE_URL=postgres://jurgen@localhost:5432/webdl

# Eigen schema binnen die DB, zodat we niet botsen met simple-server.
DB_SCHEMA=webdl

# Map waarin nieuwe hub-downloads terechtkomen.
# Bestaande gallery-paden mogen op andere WEBDL-roots blijven staan.
DOWNLOAD_ROOT=./data/downloads

# SABNZBD completed-mappen die door de hub in de gallery worden geimporteerd.
# Meerdere roots scheiden met puntkomma.
WEBDL_SABNZBD_COMPLETED_DIRS=/Volumes/HDD - One Touch/WEBDL/_SABNZBD/Completed;/Volumes/WEBDL Extra/WEBDL/_SABNZBD/Completed

# WEBDL media roots voor status/ruimte-overzicht.
WEBDL_STORAGE_ROOTS=/Volumes/HDD - One Touch/WEBDL;/Volumes/WEBDL Extra/WEBDL

# Beperk SAB watcher scans zodat oude Completed-roots de hub niet blokkeren.
WEBDL_SABNZBD_STARTUP_LOOKBACK_MS=86400000
WEBDL_SABNZBD_MAX_FILES_PER_SCAN=500

# Hoeveel jobs tegelijk mogen draaien.
WORKER_CONCURRENCY=2

# Logniveau: debug | info | warn | error
LOG_LEVEL=info

{
  "name": "webdl-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Centrale download-hub die alle WEBDL-tools (yt-dlp, gallery-dl, reddit-dl, tdl, ofscraper, instaloader) orchestreert.",
  "type": "commonjs",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "test": "node --test --test-reporter=spec 'test/**/*.test.js'",
    "test:online": "TEST_ONLINE=1 node --test --test-reporter=spec 'test/**/*.test.js'",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "prettier": "^3.3.3"
  }
}

{
  "manifest_version": 2,
  "name": "Screen Recorder Controller",
  "version": "1.0.16",
  "description": "Besturingsinterface voor de native Screen Recorder applicatie",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "*://*.footfetishforum.com/*",
    "*://*.amateurvoyeurforum.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["background/browser-polyfill.js", "content/debug-toolbar.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": ["background/browser-polyfill.js", "background/socket.io.min.js", "background/simple-background.js"]
  },
  "web_accessible_resources": [
    "icons/*.svg",
    "content/*.css",
    "content/*.js",
    "background/*.js"
  ]
}
